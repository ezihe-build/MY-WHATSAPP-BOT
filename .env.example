# ============================================
# EZIHE SUPER BOT - CONFIGURATION
# ============================================

# Required: Get from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Required: Your Telegram User ID (Owner)
OWNER_ID=your_telegram_user_id

# Bot Password (default: ezihe)
BOT_PASSWORD=ezihe

# Session Name
SESSION_NAME=ezihe-bot-session

# ============================================
# AI API KEYS (Optional - for AI features)
# ============================================

# OpenAI API Key for AI features
OPENAI_API_KEY=your_openai_api_key

# Stability AI Key for Image Generation
STABILITY_API_KEY=your_stability_api_key

# Runway ML for Video Generation
RUNWAY_API_KEY=your_runway_api_key

# ============================================
# DATABASE
# ============================================

# SQLite Database Path
DB_PATH=./data/ezihe_bot.db

# ============================================
# WEBHOOK SETTINGS (Optional - for production)
# ============================================

# WEBHOOK_URL=https://your-domain.com/webhook
# WEBHOOK_PORT=3000

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info
LOG_FILE=./logs/bot.log
